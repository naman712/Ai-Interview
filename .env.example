# Copy this to .env.local for local dev
# Set all variables in Vercel dashboard → Settings → Environment Variables

# ── Firebase ─────────────────────────────────────────────────────────
# Firebase console → Project Settings → General → Project ID
FIREBASE_PROJECT_ID=your-project-id

# Firebase console → Project Settings → Service Accounts → Generate new private key
# Open the downloaded JSON and copy client_email and private_key:
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ── Google Sheets mirror (optional) ──────────────────────────────────
# The sheet ID is in the URL:
#   https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
# Sheet tab must be named "Candidates" with headers:
#   Name | Email | Status | AI Score | AI Feedback | Suspicion Flags | Interviewed At | Transcript
#
# One-time setup:
#   1. Google Cloud Console (same project as Firebase) → Enable "Google Sheets API"
#   2. Share your Google Sheet with FIREBASE_CLIENT_EMAIL as Editor
GOOGLE_SHEET_ID=your-sheet-id-here

# ── Admin Panel ───────────────────────────────────────────────────────
# Accessible at /admin — set any strong password
ADMIN_PASSWORD=choose-a-strong-password-here

# ── OpenRouter ───────────────────────────────────────────────────────
# Get your key at openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# Free OpenRouter models (all end in :free — no billing required)
# Options:
#   meta-llama/llama-3.1-8b-instruct:free   ← recommended, strong reasoning
#   meta-llama/llama-3.2-3b-instruct:free   ← faster, lighter
#   google/gemma-3-12b-it:free              ← Google, good quality
#   google/gemma-2-9b-it:free
#   qwen/qwen-2-7b-instruct:free
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
